# Copiez vers .env.local sur le Raspberry Pi :
#   cp .env.raspberry.example .env.local
#
# MariaDB : conteneur vivian-db-1 (~/docker-compose.yml, port hôte 127.0.0.1:3307)
# phpMyAdmin : http://127.0.0.1:9010 → base « nafy-application »

APP_ENV=prod
APP_SECRET=REMPLACEZ_PAR_UN_SECRET_ALEATOIRE_32_CHARS
DEFAULT_URI=http://100.0.0.0:8319

DB_USER=vivian
DB_PASSWORD=REMPLACEZ_PAR_LE_MOT_DE_PASSE_MYSQL_USER

DATABASE_URL="mysql://vivian:REMPLACEZ_PAR_LE_MOT_DE_PASSE_MYSQL_USER@db:3306/nafy-application?serverVersion=12.3.2-MariaDB&charset=utf8mb4"
CORS_ALLOW_ORIGIN='^https?://.*$'

MAILER_DSN=null://null
